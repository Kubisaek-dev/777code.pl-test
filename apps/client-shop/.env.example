PORT=3000
SITE_URL=http://localhost:3000
LICENSE_KEY=LIC-REPLACE_ME
LICENSE_API_BASE=http://localhost:4000

YSHOP_API_BASE=https://api.yshop.pl
# Public key z panelu yshop (np. publ_...)
YSHOP_PUBLIC_KEY=publ_xxx
# Private/secret key z panelu yshop (np. priv_...)
YSHOP_PRIVATE_KEY=priv_xxx

# Domyślny slug sklepu (opcjonalnie), np. asdas715612as
YSHOP_SHOP_SLUG=

# Kompatybilność ze starym nazewnictwem (opcjonalnie zamiast powyższych):
# PUBLIC_API_KEY=publ_xxx
# PRIVATE_API_KEY=priv_xxx

# Wymagane nagłówki platformy wg OAS yshop.pl
YSHOP_PLATFORM=platform/web
YSHOP_PLATFORM_VERSION=1.0.0
YSHOP_PLATFORM_ENGINE=yshop-itemshop-license-suite
